# ── Local Development ─────────────────────────────────────────────────────────
# SQLite (no setup needed) — just works out of the box
DATABASE_URL=sqlite:///./moodreads.db

# ── Production (Render / Railway) ────────────────────────────────────────────
# Switch to PostgreSQL connection string from your hosting provider
# DATABASE_URL=postgresql://user:password@host:5432/moodreads

# ── Auth ─────────────────────────────────────────────────────────────────────
# Change this to any long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── AI Features ──────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
# Without this, AI features degrade gracefully (tag-based fallback)
ANTHROPIC_API_KEY=

# ── CORS (Production only) ───────────────────────────────────────────────────
# Set this to your deployed frontend URL
# FRONTEND_URL=https://moodreads-frontend.onrender.com
